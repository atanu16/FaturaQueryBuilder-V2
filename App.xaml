<Application x:Class="FaturaQueryBuilder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Fonts -->
            <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>

            <!-- Corner Radii -->
            <CornerRadius x:Key="RadiusSm">6</CornerRadius>
            <CornerRadius x:Key="RadiusMd">10</CornerRadius>
            <CornerRadius x:Key="RadiusLg">14</CornerRadius>
            <CornerRadius x:Key="RadiusXl">18</CornerRadius>

            <!-- Scrollbar Style -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{DynamicResource ScrollThumbBrush}"
                                                                    CornerRadius="3" Margin="0,2"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
