<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#EDE3D0"/>

    <!-- Card / Glass panels -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E2E5EA"/>
    <SolidColorBrush x:Key="GlassOverlayBrush" Color="#B3FFFFFF"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1D23"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9CA3AF"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#10B981"/>

    <!-- Accent / Primary -->
    <SolidColorBrush x:Key="AccentBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#059669"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#047857"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>

    <!-- Secondary button -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#374151"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#DC2626"/>

    <!-- Toast -->
    <SolidColorBrush x:Key="ToastBackgroundBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="ToastForegroundBrush" Color="#FFFFFF"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#C4C9D1"/>

    <!-- Badge -->
    <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#ECFDF5"/>
    <SolidColorBrush x:Key="BadgeForegroundBrush" Color="#065F46"/>

    <!-- Shadow (used via Effect) -->
    <Color x:Key="ShadowColor">#20000000</Color>

    <!-- Toggle -->
    <SolidColorBrush x:Key="ToggleOffBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="ToggleOnBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="ToggleThumbBrush" Color="#FFFFFF"/>

</ResourceDictionary>
